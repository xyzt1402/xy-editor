        "@xy-editor/ui-tokens": "workspace:*"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "react": "^18.2.0",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "vitest": "^1.0.0"
