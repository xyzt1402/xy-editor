{
    "name": "@xy-editor/react",
    "version": "0.0.1",
    "description": "React components for xy-editor",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
